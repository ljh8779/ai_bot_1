APP_NAME=groupware-rag-bot
APP_ENV=dev
LLM_PROVIDER=google
EMBEDDING_PROVIDER=google
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=2
LLM_CHAT_TEMPERATURE=0.2
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com
GOOGLE_API_KEY=your_google_ai_api_key_here
GOOGLE_EMBEDDING_MODEL=gemini-embedding-001
GOOGLE_CHAT_MODEL=gemini-2.5-flash
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=qwen2.5:7b
HF_EMBEDDING_MODEL=nlpai-lab/KURE-v1
DATABASE_URL=postgresql+psycopg://rag_user:rag_pass@db:5432/rag_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
EMBEDDING_DIMENSIONS=768
CHUNK_SIZE=1200
CHUNK_OVERLAP=400
INGEST_EMBEDDING_BATCH_SIZE=64
MAX_CONTEXT_CHUNKS=5
SEARCH_CANDIDATE_MULTIPLIER=4
ALLOW_GENERAL_FALLBACK=true
GENERAL_FALLBACK_MIN_SCORE=0.70
MAX_UPLOAD_SIZE_MB=20
BULK_INGEST_DIR=/bulk_ingest
BULK_INGEST_MAX_FILES=1000
BULK_INGEST_ZIP_MEMBER_LIMIT=2000
BULK_INGEST_DETAILS_LIMIT=300
PDF_OCR_ENABLED=true
PDF_OCR_MAX_PAGES=20
PDF_OCR_DPI=200
PDF_OCR_FALLBACK_MIN_CHARS=40
OCR_TESSERACT_LANG=kor+eng
NOTION_API_KEY=
